{
    "name": "auth-service",
    "version": "1.0.0",
    "description": "user management service",
    "main": "index.js",
    "type": "module",
    "scripts": {
        "dev": "cross-env NODE_ENV=dev nodemon",
        "build": "tsc -p tsconfig.json",
        "docker:build": "docker build -t auth-service:dev -f docker/dev/Dockerfile .",
        "docker:run": "docker run --rm -it -v $(pwd):/usr/src/app -v /usr/src/app/node_modules --env-file $(pwd)/.env -p 5501:5501 -e NODE_ENV=dev auth-service:dev",
        "docker:db": "docker run --rm --name mernpg-container -e POSTGRES_USER=root -e POSTGRES_PASSWORD=root -v mernpgdata:/var/lib/postgresql -p 5432:5432 -d postgres",
        "format:fix": "prettier . --write",
        "format:check": "prettier . --check",
        "lint:check": "eslint .",
        "lint:fix": "eslint . --fix",
        "test": "NODE_OPTIONS=--experimental-vm-modules jest --no-cache --coverage --all --runInBand",
        "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch --runInBand",
        "start": "ts-node src/index.ts",
        "prepare": "husky",
        "migration:generate": "typeorm-ts-node-esm migration:generate",
        "migration:run": "typeorm-ts-node-esm migration:run",
        "migration:create": "typeorm-ts-node-esm migration:create"
    },
    "author": "Mr. Paradox avyas8927@gmail.com",
    "license": "ISC",
    "devDependencies": {
        "@eslint/js": "^9.38.0",
        "@jest/globals": "30.3.0",
        "@types/bcrypt": "^6.0.0",
        "@types/cookie-parser": "^1.4.10",
        "@types/express": "^5.0.6",
        "@types/http-errors": "^2.0.5",
        "@types/jest": "^30.0.0",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/mocha": "^10.0.10",
        "@types/node": "^24.10.4",
        "@types/supertest": "^6.0.3",
        "cross-env": "^10.1.0",
        "eslint": "^9.38.0",
        "husky": "^9.1.7",
        "jest": "^30.2.0",
        "lint-staged": "^16.2.7",
        "mock-jwks": "^3.3.4",
        "nodemon": "^3.1.11",
        "prettier": "3.6.2",
        "ts-jest": "^29.4.6",
        "ts-node": "^10.9.2",
        "ts-node-dev": "^2.0.0",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.46.2"
    },
    "pnpm": {
        "overrides": {
            "jose": "4.15.9"
        }
    },
    "lint-staged": {
        "*.ts": [
            "npm run format:fix",
            "npm run lint:fix"
        ]
    },
    "dependencies": {
        "bcrypt": "^6.0.0",
        "cookie-parser": "^1.4.7",
        "dotenv": "^17.2.3",
        "express": "^5.2.1",
        "express-jwt": "^8.5.1",
        "express-validator": "^7.3.1",
        "http-errors": "^2.0.1",
        "jsonwebtoken": "^9.0.3",
        "jwks-rsa": "^4.0.1",
        "pg": "^8.16.3",
        "reflect-metadata": "^0.2.2",
        "rsa-pem-to-jwk": "^1.1.3",
        "supertest": "^7.1.4",
        "typeorm": "^0.3.28",
        "winston": "^3.19.0"
    }
}
